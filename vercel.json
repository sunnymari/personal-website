{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "rewrites": [
    {
      "source": "/api/carbonbench/:path*",
      "destination": "https://carbonbench.ai/api/:path*"
    },
    {
      "source": "/about",
      "destination": "/about.html"
    },
    {
      "source": "/projects",
      "destination": "/projects.html"
    },
    {
      "source": "/reading",
      "destination": "/reading.html"
    },
    {
      "source": "/blog",
      "destination": "/blog.html"
    },
    {
      "source": "/data-center-watch",
      "destination": "/data-center-watch.html"
    }
  ],
  "redirects": [
    {
      "source": "/work-with-me",
      "destination": "/",
      "permanent": true
    },
    {
      "source": "/work-with-me.html",
      "destination": "/",
      "permanent": true
    },
    {
      "source": "/chibi",
      "destination": "/",
      "permanent": true
    },
    {
      "source": "/chibi.html",
      "destination": "/",
      "permanent": true
    },
    {
      "source": "/pageant",
      "destination": "/",
      "permanent": false
    },
    {
      "source": "/pageant.html",
      "destination": "/",
      "permanent": false
    }
  ],
  "functions": {
    "api/waitlist.js": {
      "maxDuration": 10
    }
  },
  "headers": [
    {
      "source": "/(.*\\.html)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-store, max-age=0, must-revalidate"
        }
      ]
    }
  ]
}
