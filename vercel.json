{
  "version": 2,
  "builds": [
    {
      "src": "**",
      "use": "@vercel/static"
    }
  ],
  "rewrites": [
    {
      "source": "/about",
      "destination": "/about.html"
    },
    {
      "source": "/projects",
      "destination": "/projects.html"
    },
    {
      "source": "/reading",
      "destination": "/reading.html"
    },
    {
      "source": "/blog",
      "destination": "/blog.html"
    },
    {
      "source": "/pageant",
      "destination": "/pageant.html"
    },
    {
      "source": "/vendor/(.*)",
      "destination": "/public/vendor/$1"
    },
    {
      "source": "/bookicon.png",
      "destination": "/public/bookicon.png"
    },
    {
      "source": "/cornerUI.png",
      "destination": "/public/cornerUI.png"
    },
    {
      "source": "/Meshy_AI_Animation_Idle_11_withSkin.glb",
      "destination": "/public/Meshy_AI_Animation_Idle_11_withSkin.glb"
    },
    {
      "source": "/Meshy_AI_Animation_air_squat_withSkin.glb",
      "destination": "/public/Meshy_AI_Animation_air_squat_withSkin.glb"
    },
    {
      "source": "/pop.mp3",
      "destination": "/public/pop.mp3"
    }
  ],
  "headers": [
    {
      "source": "/(.*\\.html)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=3600"
        }
      ]
    },
    {
      "source": "/about.html",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-cache"
        }
      ]
    }
  ]
}

